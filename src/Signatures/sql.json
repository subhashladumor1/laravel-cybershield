    {
        "id": "SQLI-002",
        "name": "Blind SQL Injection",
        "description": "Detects time-delay based SQL injection patterns",
        "severity": "high",
        "impact_score": 8.5,
        "patterns": [
            {
                "regex": "/(sleep|benchmark|waitfor)/i",
                "description": "Time delay functions"
            }
        ],
        "tags": ["sql", "sqli", "blind"]
    },
    {
        "id": "SQLI-003",
        "name": "SQL Comment Injection",
        "description": "Detects SQL comment syntax used to truncate queries",
        "severity": "medium",
        "impact_score": 6.0,
        "patterns": [
            {
                "regex": "/(--\\s|#\\s|\\/\\*[\\s\\S]*?\\*\\/)/",
                "description": "SQL comment syntax"
            }
        ],
        "tags": ["sql", "sqli", "comment"]
    }
