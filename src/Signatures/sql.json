        "id": "SQLI-001",
        "name": "Basic SQL Injection",
        "description": "Detects common SQL keywords used in injection attacks",
        "severity": "critical",
        "impact_score": 9.5,
        "patterns": [
            {
                "regex": "/(union|select|insert|update|delete|drop|alter|truncate)/i",
